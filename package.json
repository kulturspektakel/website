{
  "name": "website-tanstack",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "vite start",
    "generate:prisma": "prisma generate",
    "generate:proto": "protoc --plugin=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=./src/proto --ts_proto_opt=esModuleInterop=true,forceLong=number,useOptionals=messages -I ./src/proto ./src/proto/noise.proto ./src/proto/product.proto ./src/proto/config.proto ./src/proto/configs.proto ./src/proto/logmessage.proto",
    "generate:theme": "chakra typegen app/theme.ts --strict",
    "generate:env": "dotenv-vault pull",
    "generate:mail": "maizzle build --config ./maizzle/config.production.js",
    "mail": "maizzle serve --config ./maizzle/config.js",
    "sync:env": "node scripts/sync-env.js",
    "email:band-infosheet": "tsx scripts/bandInfosheet.ts",
    "email:band-lineup": "tsx scripts/bandLineup.ts",
    "email:band-rejection": "tsx scripts/bandRejectionMail.ts",
    "email:donations": "tsx scripts/donations.ts",
    "test": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@chakra-ui/cli": "3.36.0",
    "@google-cloud/secret-manager": "^6.1.2",
    "@maizzle/framework": "^5.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@types/google.maps": "^3.58.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",

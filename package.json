    "bufferutil": "^4.1.0",
    "dotenv-vault": "^1.27.0",
    "pg": "^8.21.0",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "tailwindcss-email-variants": "^3.0.5",
    "ts-proto": "^2.11.8",
    "tsx": "^4.22.4",
